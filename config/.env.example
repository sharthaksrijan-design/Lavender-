# ─────────────────────────────────────────────────────────────────────────────
# LAVENDER — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── ELEVENLABS ───────────────────────────────────────────────────────────────
# Get your API key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_api_key_here

# Voice IDs for each personality.
# Find voice IDs in your ElevenLabs dashboard under Voices.
# Recommended voice characteristics per personality:
#   IRIS   → calm, precise, slightly cool and measured
#   NOVA   → warm, clear, friendly, slightly upbeat
#   VECTOR → confident, measured, like a senior engineer
#   SOLACE → gentle, slow, soft, unhurried
#   LILAC  → dry, deliberate, intelligent, quietly devastating
VOICE_IRIS=voice_id_here
VOICE_NOVA=voice_id_here
VOICE_VECTOR=voice_id_here
VOICE_SOLACE=voice_id_here
VOICE_LILAC=voice_id_here

# ── OLLAMA ───────────────────────────────────────────────────────────────────
# Leave as default unless you're running Ollama on a different machine
OLLAMA_BASE_URL=http://localhost:11434

# ── OPTIONAL: CLOUD FALLBACK ─────────────────────────────────────────────────
# Used only when local model confidence is low or user requests maximum quality
# Leave blank to disable cloud fallback entirely
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── OPTIONAL: HOME ASSISTANT ─────────────────────────────────────────────────
# Needed for Milestone 5 (device control). Leave blank for now.
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# ── SYSTEM ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
